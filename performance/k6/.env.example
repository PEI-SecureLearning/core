# Copy this file to performance/k6/.env and fill in the values you need.

# Common
K6_BASE_URL=http://localhost:8000
K6_DURATION=1m
K6_PREALLOCATED_VUS=5
K6_MAX_VUS=20

# Public API
K6_LOOKUP_DOMAIN=ua.pt

# Authenticated runs
K6_AUTH_TOKEN=replace-with-a-valid-bearer-token
K6_REALM=ua
K6_USER_ID=replace-with-an-existing-user-id
K6_COURSE_ID=replace-with-an-existing-course-id

# Authenticated API rates
K6_USERS_RATE=5
K6_USER_DETAILS_RATE=3

# Base user rates
K6_PROFILE_RATE=5
K6_ENROLLED_RATE=5
K6_PROGRESS_RATE=5
K6_CERTIFICATES_RATE=3
K6_ME_STATS_RATE=3
K6_COMPLIANCE_RATE=3
K6_COMPLIANCE_DOC_RATE=2
K6_COMPLIANCE_QUIZ_RATE=2
K6_COURSE_PROGRESS_RATE=3

# Bulk user creation
K6_BULK_EMAIL_DOMAIN=ua.pt
K6_BULK_CREATE_RATE=1
K6_BULK_BATCH_SIZE=10
K6_BULK_USER_ROLE=DEFAULT_USER
K6_BULK_USERNAME_PREFIX=k6bulk
K6_BULK_GROUP_ID=
