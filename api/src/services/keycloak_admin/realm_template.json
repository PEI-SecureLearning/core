{
    "realm": "your_realm_name",
    "enabled": true,
    "realm_roles": [
        {
            "name": "ORG_MANAGER",
            "description": "Custom administrator role for the organization"
        },
        {
            "name": "DEFAULT_USER",
            "description": "Custom role for read-only access"
        }
    ],
    "clients": [
        {
            "clientId": "react-app",
            "enabled": true,
            "publicClient": true,
            "redirectUris": [
                "{web_url}/*"
            ],
            "webOrigins": [
                "{web_url}"
            ],
            "standardFlowEnabled": true,
            "directAccessGrantsEnabled": true,
            "protocolMappers": [
                {
                    "name": "api-audience",
                    "protocol": "openid-connect",
                    "protocolMapper": "oidc-audience-mapper",
                    "config": {
                        "included.client.audience": "api",
                        "id.token.claim": "false",
                        "access.token.claim": "true",
                        "introspection.token.claim": "true"
                    }
                }
            ]
        },
        {
            "clientId": "api",
            "enabled": true,
            "serviceAccountsEnabled": true,
            "authorizationServicesEnabled": true,
            "authorizationSettings": {
                "allowRemoteResourceManagement": true,
                "policyEnforcementMode": "ENFORCING",
                "resources": [
                    {
                        "name": "org_manager",
                        "type": "urn:api:resources:org_manager",
                        "displayName": "Organization Manager Resource",
                        "uris": [
                            "/api/org-manager/*"
                        ],
                        "scopes": [
                            {
                                "name": "view"
                            },
                            {
                                "name": "manage"
                            }
                        ]
                    },
                    {
                        "name": "default_user",
                        "type": "urn:api:resources:default_user",
                        "displayName": "Default User Resource",
                        "uris": [
                            "/api/default-user/*"
                        ],
                        "scopes": [
                            {
                                "name": "view"
                            },
                            {
                                "name": "manage"
                            }
                        ]
                    }
                ],
                "policies": [
                    {
                        "name": "ORG_MANAGER Role Policy",
                        "type": "role",
                        "config": {
                            "roles": "[{\"id\":\"ORG_MANAGER\"}]"
                        }
                    },
                    {
                        "name": "org_manager Permission",
                        "type": "resource",
                        "config": {
                            "resources": "[\"org_manager\"]",
                            "applyPolicies": "[\"ORG_MANAGER Role Policy\"]"
                        }
                    },
                    {
                        "name": "DEFAULT_USER Role Policy",
                        "type": "role",
                        "config": {
                            "roles": "[{\"id\":\"DEFAULT_USER\"}]"
                        }
                    },
                    {
                        "name": "default_user Permission",
                        "type": "resource",
                        "config": {
                            "resources": "[\"default_user\"]",
                            "applyPolicies": "[\"DEFAULT_USER Role Policy\"]"
                        }
                    }
                ],
                "scopes": [
                    {
                        "name": "view"
                    },
                    {
                        "name": "manage"
                    }
                ]
            }
        }
    ],
    "users": [
        {
            "username": "Org_manager",
            "enabled": true,
            "email": "{admin_email}",
            "credentials": [
                {
                    "type": "password",
                    "value": "1234",
                    "temporary": true
                }
            ],
            "realmRoles": [
                "ORG_MANAGER"
            ],
            "clientRoles": {
                "realm-management": [
                    "realm-admin"
                ]
            }
        }
    ]
}